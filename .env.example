# ============================================================
# 🚀 Thikedar App - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Database ---
# PostgreSQL connection string (RDS or local)
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgres://postgres:YourPassword@localhost:5432/thikedar"

# --- Authentication ---
# JWT secret key (use a strong random string)
# Generate with: openssl rand -hex 32
JWT_SECRET="your-random-jwt-secret-at-least-32-chars-long"

# --- App Configuration ---
NODE_ENV="development"
# Options: development | production

# --- Optional: Gemini AI (if using AI features) ---
GEMINI_API_KEY=""

# --- Optional: App URL for callbacks ---
APP_URL="http://localhost:3000"
